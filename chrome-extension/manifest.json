{
  "manifest_version": 3,
  "name": "note → X 拡散ツール",
  "version": "1.1",
  "description": "noteの記事を開くだけでXに自動投稿。APIキー不要・完全無料でnote記事をXで拡散してフォロワーと売上を増やす。",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://note.com/*", "https://twitter.com/*", "https://x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://note.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://twitter.com/intent/tweet*", "https://x.com/intent/tweet*"],
      "js": ["autopost.js"],
      "run_at": "document_idle"
    }
  ]
}
